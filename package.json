{
  "name": "domenico-rizzi-portfolio",
  "version": "1.0.0",
  "description": "Portfolio professionale — Cybersecurity & Cloud Engineer",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
